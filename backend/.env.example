# 服务监听
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LangSmith / LangGraph Studio
# LANGSMITH_API_KEY=lsv2_xxx
LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=helloagents-deepresearch
# LANGSMITH_WORKSPACE_ID=your-workspace-id

# 默认主模型：DeepSeek OpenAI-compatible API
LLM_PROVIDER=custom
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-chat
SMART_LLM=deepseek-chat
STRATEGIC_LLM=deepseek-reasoner

# 搜索后端: duckduckgo / tavily / perplexity / searxng / advanced
SEARCH_API=duckduckgo
FETCH_FULL_PAGE=true
# TAVILY_API_KEY=tvly-xxxxx
# PERPLEXITY_API_KEY=pplx-xxxxx
# PERPLEXITY_MODEL=sonar
# SEARXNG_URL=http://localhost:8888

# 研究参数
DEEP_RESEARCH_BREADTH=3
DEEP_RESEARCH_DEPTH=2
DEEP_RESEARCH_CONCURRENCY=4
MAX_WEB_RESEARCH_LOOPS=3
MAX_REVISIONS=2

# 语义压缩
EMBEDDING_MODEL=openai:text-embedding-3-small
SIMILARITY_THRESHOLD=0.42
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama / LMStudio 示例
# LLM_PROVIDER=ollama
# LOCAL_LLM=qwen2.5:14b
# OLLAMA_BASE_URL=http://localhost:11434
# SMART_LLM=ollama:qwen2.5:14b
# STRATEGIC_LLM=ollama:qwen2.5:14b

# LLM_PROVIDER=lmstudio
# LOCAL_LLM=qwen_qwq-32b
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# 其他
LOG_LEVEL=INFO
STRIP_THINKING_TOKENS=true
